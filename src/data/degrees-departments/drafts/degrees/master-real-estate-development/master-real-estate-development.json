    {
      "id": "1",
      "text": "Students must enroll for at least 6 units from this list each semester. Enrollment in 12 units per semester is strongly recommended for timely progress."
    },
    {
      "id": "2",
      "text": "Suggested subjects (based on what students have taken in the past) are listed below, but students are free to choose from among MIT's offerings. CRE periodically offers additional Special Topics in Real Estate courses, which may be applied toward the Unrestricted Elective requirement."
    },
    {
      "id": "3",
      "text": "Students must register for 12 units of thesis credit under RED.THG in their third (final) semester."
    }
  ],
