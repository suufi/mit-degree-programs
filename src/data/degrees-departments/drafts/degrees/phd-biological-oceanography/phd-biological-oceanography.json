  "footnotes": [
    {
      "id": "1",
      "text": "Harvard courses OEB137 Experimental Design and Statistics for Ecology and_<br>_MCB 112 Biological Data Analysis may also be used to satisfy this requirement."
    },
    {
      "id": "2",
      "text": "Other relevant courses can be requested by petition to the Joint Committee on Biological Oceanography."
    },
    {
      "id": "3",
      "text": "Up to 12 of the 24 units may come from Topics subjects."
    },
    {
      "id": "4",
      "text": "Biological oceanography students whose home department is Civil and Environmental Engineering register for 1.THG whether they are completing pre-thesis or thesis research, for a total of 384–492 units of 1.THG over the course of the five-year doctoral program"
    }
  ],
